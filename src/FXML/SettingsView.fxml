<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="FarmController.SettingsController"
            prefWidth="430" prefHeight="320"
            styleClass="settings-root"
            stylesheets="@../FarmView/settings.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="settings-top">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label fx:id="headerLabel" text="⚙ PARAMETRES" styleClass="settings-title"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="14" styleClass="settings-body">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <VBox spacing="6">
                <Label fx:id="autosaveLabel" text="Autosave" styleClass="settings-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Slider fx:id="autosaveSlider" min="30" max="600" blockIncrement="10" prefWidth="250"/>
                    <Label fx:id="autosaveValueLabel" styleClass="settings-value"/>
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label fx:id="volumeLabel" text="Volume" styleClass="settings-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Slider fx:id="volumeSlider" min="0" max="100" blockIncrement="5" prefWidth="250"/>
                    <Label fx:id="volumeValueLabel" styleClass="settings-value"/>
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label fx:id="languageLabel" text="Langue" styleClass="settings-label"/>
                <ComboBox fx:id="languageCombo" prefWidth="180"/>
            </VBox>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="settings-footer">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button fx:id="cancelBtn" text="Annuler" onAction="#onCancel" styleClass="settings-btn-cancel"/>
            <Button fx:id="applyBtn" text="Appliquer" onAction="#onApplySettings" styleClass="settings-btn-apply"/>
        </HBox>
    </bottom>
</BorderPane>
