<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-border-color: #ecf0f1; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FarmController.SaveChoiceController">
    <children>
        <Label text="CHOISIR UNE SAUVEGARDE" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

        <VBox spacing="10.0">
            <Button fx:id="slot1Btn" maxWidth="Infinity" onAction="#selectSlot1" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-padding: 15; -fx-cursor: hand;" text="Slot 1 : Vide" />
            <Button fx:id="slot2Btn" maxWidth="Infinity" onAction="#selectSlot2" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-padding: 15; -fx-cursor: hand;" text="Slot 2 : Vide" />
            <Button fx:id="slot3Btn" maxWidth="Infinity" onAction="#selectSlot3" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-padding: 15; -fx-cursor: hand;" text="Slot 3 : Vide" />
        </VBox>

        <Button onAction="#close" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Annuler" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>