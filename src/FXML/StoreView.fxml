<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" spacing="0" prefWidth="600.0" prefHeight="700.0"
      style="-fx-background-color: #3e2723;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="FarmController.StoreController">

    <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20; -fx-background-color: rgba(0,0,0,0.2);">
        <Text text="MAGASIN DE LA FERME" style="-fx-fill: white; -fx-font-size: 28; -fx-font-weight: bold;" />
        <Label fx:id="moneyLabel" text="Argent : 0 $" textFill="#FFD700" style="-fx-font-size: 18; -fx-font-weight: bold;" />
        <Separator />
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox spacing="12" style="-fx-padding: 20;">

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🌾 Wheat (5 $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Wheat_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="wheatSellLabel" text="Vente: 8$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="Carrot (180 $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Carrot_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="carrotSellLabel" text="Vente: 200$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🥔 Potato (850 $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Potato_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="potatoSellLabel" text="Vente: 900$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🍅 Tomato (3.5K $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Tomato_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="tomatoSellLabel" text="Vente: 4K$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="Kiwi (15K $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Kiwi_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="kiwiSellLabel" text="Vente: 18K$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🍓 Strawberry (60K $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Strawberry_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="strawberrySellLabel" text="Vente: 70K$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🌽 Corn (250K $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Corn_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="cornSellLabel" text="Vente: 280K$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 5;">
                <Label text="🎃 Pumpkin (950K $)" textFill="white" style="-fx-font-size: 16;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5">
                    <Button text="Acheter" fx:id="Pumpkin_Seed" onAction="#buySeeds" prefWidth="120"/>
                    <Label fx:id="pumpkinSellLabel" text="Vente: 1.1M$" textFill="#81c784" style="-fx-font-size: 12;" />
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

    <VBox spacing="15" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: rgba(0,0,0,0.2);">
        <Separator />
        <HBox spacing="20" alignment="CENTER">
            <Button text="FERMER" onAction="#closeStore" prefWidth="120" style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Button text="VENDRE RÉCOLTES" onAction="#sellingCrops" prefWidth="180" style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>
    </VBox>
</VBox>