<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="15" prefWidth="400.0" style="-fx-background-color: #3e2723; -fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="FarmController.StoreController">

    <Text text="MAGASIN DE LA FERME" style="-fx-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />

    <Separator />

    <VBox spacing="10">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🌾 Wheat (5 $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Wheat_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🥕 Carrot (180 $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Carrot_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🥔 Potato (850 $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Potato_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🍅 Tomato (3.5K $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Tomato_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🥝 Kiwi (15K $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Kiwi_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🍓 Strawberry (60K $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Strawberry_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🌽 Corn (250K $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Corn_Seed" onAction="#buySeeds"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="🎃 Pumpkin (950K $)" textFill="white" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Acheter" fx:id="Pumpkin_Seed" onAction="#buySeeds"/>
        </HBox>

    </VBox>

    <Separator />
    <HBox spacing="15" alignment="CENTER">
        <Button text="Fermer" onAction="#closeStore" style="-fx-background-color: #d32f2f; -fx-text-fill: white;" />
        <Button text="Vendre" onAction="#sellingCrops" style="-fx-background-color: #d32f2f; -fx-text-fill: white;" />
    </HBox>
</VBox>