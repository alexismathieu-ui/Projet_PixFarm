<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #5e9741;"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FarmController.MainController">

    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(0,0,0,0.5); -fx-padding: 10;">
            <Label fx:id="moneyLabel" style="-fx-text-fill: white; -fx-font-size: 20;" text="Argent: 10 $" />
            <Label fx:id="labelStatus" style="-fx-text-fill: #ffff00; -fx-font-size: 18;" text="Ready to Plant !" />
            <Button onAction="#onOpenStore" text="Market" />
            <Button onAction="#onOpenInventory" text="Inventory" />
            <Button onAction="#onActionHarvest" styleClass="pixel-button" text="Harvest" />

            <Button onAction="#goToBarn" text="Grange 🏠" style="-fx-background-color: #795548; -fx-text-fill: white;" />

            <Button onAction="#onSave" text="Saving 💾" />
        </HBox>
    </top>

    <center>
        <StackPane>
            <GridPane fx:id="farmGrid" alignment="CENTER" hgap="5" vgap="5" style="-fx-padding: 20;">
            </GridPane>
        </StackPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #2e7d32; -fx-padding: 10;">
            <Label text="SELECTION :" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="Wheat_Seed" text="🌾 Wheat" onAction="#handleselectSeed" />
            <Button fx:id="Carrot_Seed" text="🥕 Carrot" onAction="#handleselectSeed" />
            <Button fx:id="Potato_Seed" text="🥔 Potato" onAction="#handleselectSeed" />
            <Button fx:id="Tomato_Seed" text="🍅 Tomato" onAction="#handleselectSeed" />
            <Button fx:id="Kiwi_Seed" text="🥝 Kiwi" onAction="#handleselectSeed" />
            <Button fx:id="Strawberry_Seed" text="🍓 Strawberry" onAction="#handleselectSeed" />
            <Button fx:id="Corn_Seed" text="🌽 Corn" onAction="#handleselectSeed" />
            <Button fx:id="Pumpkin_Seed" text="🎃 Pumpkin" onAction="#handleselectSeed" />
        </HBox>
    </bottom>

</BorderPane>