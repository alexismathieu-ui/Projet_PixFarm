<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="768.0" prefWidth="1024.0"
            style="-fx-background-color: #5e9741;"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FarmController.MainController">

    <top>
        <HBox alignment="CENTER" spacing="40" style="-fx-background-color: rgba(0,0,0,0.7); -fx-padding: 15;">
            <VBox alignment="CENTER" spacing="5">
                <Label fx:id="levelLabel" text="Niveau 1" style="-fx-text-fill: #FFD700; -fx-font-weight: bold; -fx-font-size: 16;"/>
                <ProgressBar fx:id="xpBar" progress="0.0" prefWidth="250" style="-fx-accent: #4CAF50; -fx-pref-height: 15;"/>
                <Label fx:id="xpLabel" text="0 / 100 XP" style="-fx-text-fill: white; -fx-font-size: 11;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="5">
                <Label fx:id="moneyLabel" style="-fx-text-fill: #85bb65; -fx-font-size: 24; -fx-font-weight: bold;" text="10 $" />
                <Label fx:id="labelStatus" style="-fx-text-fill: white; -fx-font-style: italic;" text="Prêt à planter !" />
            </VBox>

            <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 5 15; -fx-background-radius: 10;">
                <Label fx:id="weatherLabel" text="☀️ Soleil (x1.0)" style="-fx-text-fill: #00d4ff; -fx-font-weight: bold; -fx-font-size: 14;"/>
            </VBox>
        </HBox>
    </top>

    <left>
        <VBox spacing="15" alignment="TOP_CENTER" style="-fx-background-color: rgba(0,0,0,0.4); -fx-padding: 20; -fx-min-width: 150;">
            <Label text="MENUS" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button onAction="#onOpenStore" text="Marchand 🛒" maxWidth="Infinity" style="-fx-min-height: 40;"/>
            <Button onAction="#onOpenInventory" text="Sac à dos 🎒" maxWidth="Infinity" style="-fx-min-height: 40;"/>
            <Button onAction="#onOpenQuestBoard" text="Quest Board 📅" maxWidth="Infinity" style="-fx-background-color: #499ED1; -fx-text-fill: white;-fx-min-height: 40;"/>
            <Button fx:id="barnButton" onAction="#goToBarn" text="Grange 🏠" maxWidth="Infinity"
                    style="-fx-background-color: #795548; -fx-text-fill: white; -fx-min-height: 40;"/>

            <Region VBox.vgrow="ALWAYS" /> <Button onAction="#onSave" text="Sauvegarder 💾" maxWidth="Infinity" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <StackPane>
                <GridPane fx:id="farmGrid" alignment="CENTER" hgap="10" vgap="10" style="-fx-padding: 30;">
                </GridPane>
            </StackPane>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #2e7d32; -fx-padding: 15;">
            <HBox alignment="CENTER" spacing="20">
                <Label text="VOS GRAINES :" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button onAction="#onActionHarvest" style="-fx-background-color: #ffa000; -fx-font-weight: bold;" text="TOUT RÉCOLTER 🧺" />
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="Wheat_Seed" text="🌾 Blé" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Carrot_Seed" text="🥕 Carotte" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Potato_Seed" text="🥔 Patate" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Tomato_Seed" text="🍅 Tomate" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Lemon_Seed" text="🍋 Citron" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Strawberry_Seed" text="🍓 Fraise" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Corn_Seed" text="🌽 Maïs" onAction="#handleselectSeed" prefWidth="100" />
                <Button fx:id="Pineapple_Seed" text="🍍 Ananas" onAction="#handleselectSeed" prefWidth="100" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>