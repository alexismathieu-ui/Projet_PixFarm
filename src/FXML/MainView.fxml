<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.effect.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="850" prefWidth="1280"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FarmController.MainController"
            stylesheets="@../FarmView/main.css">

    <top>
        <HBox alignment="CENTER" spacing="30" styleClass="top-bar">

            <VBox alignment="CENTER" spacing="4" styleClass="top-section">
                <Label fx:id="levelLabel" text="Niveau 1" styleClass="level-label"/>
                <ProgressBar fx:id="xpBar" progress="0.0" styleClass="xp-bar"/>
                <Label fx:id="xpLabel" text="0 / 100 XP" styleClass="xp-label"/>
            </VBox>

            <VBox alignment="CENTER" spacing="4" styleClass="top-section">
                <Label fx:id="moneyLabel" text="10 000 $" styleClass="money-label"/>
                <Label fx:id="labelStatus" text="Prêt à planter !" styleClass="status-label"/>
            </VBox>

            <VBox alignment="CENTER" styleClass="weather-box">
                <Label fx:id="weatherLabel" text="☀️ Soleil (x1)" styleClass="weather-label"/>
            </VBox>

        </HBox>
    </top>

    <left>
        <VBox spacing="10" alignment="TOP_CENTER" styleClass="side-bar">

            <Label text="≡  NAVIGATION" styleClass="side-title"/>
            <Region styleClass="side-separator"/>

            <Button onAction="#onOpenStore"      text="🛒  Marchand"    maxWidth="Infinity" styleClass="nav-btn"/>
            <Button onAction="#onOpenInventory"  text="🎒  Sac à dos"   maxWidth="Infinity" styleClass="nav-btn"/>
            <Button onAction="#onOpenQuestBoard" text="📋  Quêtes"      maxWidth="Infinity" styleClass="nav-btn"/>
            <Button fx:id="barnButton" onAction="#goToBarn" text="🏠  Grange" maxWidth="Infinity" styleClass="barn-btn"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Region styleClass="side-separator"/>

            <Button onAction="#onSave" text="💾  Sauvegarder" maxWidth="Infinity" styleClass="save-btn"/>

        </VBox>
    </left>

    <center>
        <ScrollPane styleClass="farm-scroll" fitToHeight="true" fitToWidth="true">
            <StackPane fx:id="farmCenter" styleClass="farm-center">
                <GridPane fx:id="farmGrid" alignment="CENTER" hgap="8" vgap="8">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                </GridPane>
            </StackPane>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="10" alignment="CENTER" styleClass="bottom-bar">

            <HBox alignment="CENTER" spacing="20">
                <Label text="🌱  VOS GRAINES :" styleClass="bottom-label"/>
                <Button onAction="#onActionHarvest" text="🧺  TOUT RÉCOLTER" styleClass="harvest-btn"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER">

                <Button fx:id="Wheat_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/BléIC.png"/></image>
                            </ImageView>
                            <Label text="Blé" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Carrot_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/CarotteIC.png"/></image>
                            </ImageView>
                            <Label text="Carotte" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Potato_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/PatateIC.png"/></image>
                            </ImageView>
                            <Label text="Patate" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Tomato_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/TomateIC.png"/></image>
                            </ImageView>
                            <Label text="Tomate" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Lemon_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/CitronIC.png"/></image>
                            </ImageView>
                            <Label text="Citron" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Strawberry_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/FraiseIC.png"/></image>
                            </ImageView>
                            <Label text="Fraise" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Corn_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/MaisIC.png"/></image>
                            </ImageView>
                            <Label text="Maïs" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="Pineapple_Seed" onAction="#handleselectSeed" styleClass="seed-btn">
                    <graphic>
                        <VBox alignment="CENTER" spacing="2">
                            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                <image><Image url="@../Sprite/images/Icons/ananasIC.png"/></image>
                            </ImageView>
                            <Label text="Ananas" style="-fx-text-fill:#e8f5e0; -fx-font-size:11px; -fx-font-weight:bold; -fx-font-family:'Courier New';"/>
                        </VBox>
                    </graphic>
                </Button>

            </HBox>
        </VBox>
    </bottom>

</BorderPane>